{
    "_producer_rules": [
        [ [ "program_output_in_docker-:program_output", "task=image_classification", "framework=onnxrt" ], [[ "get", "pipeline" ]] ],

        [ [ "program_output_in_docker-:program_output", "task=image_classification", "framework=pytorch" ], [[ "get", "pipeline" ]] ],

        [ [ "program_output_in_docker-:program_output", "task=image_classification", "framework=tf" ], [[ "get", "pipeline" ]] ],

        [ [ "program_output_in_docker-:program_output", "task=object_detection", "framework=onnxrt" ], [[ "get", "pipeline" ]] ],

        [ [ "program_output_in_docker-:program_output", "task=bert", "framework=onnxrt" ], [[ "get", "pipeline" ]] ],

        [ [ "program_output_in_docker-:program_output", "calendar" ], [[ "get", "pipeline" ]], {
                "execution_entry_name": "generate_calendar_py",
                "execution_entry_product_collection_name": "collection_name"
            } ],

        [ [ "program_output_in_docker-:program_output", "uname" ], [[ "get", "pipeline" ]], {
                "execution_entry_name": "uname_recipe",
                "execution_entry_product_collection_name": "collection_name"
            } ]
    ],

    "user_in_docker": "root",
    "docker_image": "python",
    "docker_image_tag": "3.12",
    "docker_tool": [ "^", "byquery", "shell_tool,can_docker" ],
    "docker_run_extra_options": "",

    "hostname": [ "^", "func", "socket.gethostname" ],
    "exchange_collection_name": [ "^^", "substitute", "#{docker_image}#_#{docker_image_tag}#_on_#{hostname}#_docker_exchange_collection" ],
    "pre_exchange_collection": [ "^^", "execute", [[
        [ "get_kernel" ],
        [ "byquery", [[ "collection", [ "collection_name", [ "^^", "get", "exchange_collection_name" ] ] ]], { "parent_recursion": true } ]
    ]] ],
    "pre_exchange_collection_path_on_host": [ "^^", "execute", [[
        [ "get", "pre_exchange_collection" ],
        [ "get_path", "" ]
    ]] ],

    "group_on_host": "krai",
    "exchange_collection": [ "^^", "execute", [[
        [ ".shell.run", [ "^^", "substitute", "chgrp -R #{group_on_host}# #{pre_exchange_collection_path_on_host}#" ] ],
        [ ],
        [ ".shell.run", [ "^^", "substitute", "chmod -R g+ws #{pre_exchange_collection_path_on_host}#" ] ],
        [ ],
        [ ".shell.run", [ "^^", "substitute", "setfacl -R -d -m group:#{group_on_host}#:rwx #{pre_exchange_collection_path_on_host}#" ] ],
        [ ],
        [ "get", "pre_exchange_collection" ]
    ]] ],

    "execution_entry_name": "image_classification_using_onnxrt_py",
    "execution_entry_product_collection_name": "experiment_collection_name",
    "execution_entry": [ "^^", "execute", [[
        [ "get_kernel" ],
        [ "byname", [ "^^", "get", "execution_entry_name" ] ]
    ]] ],
    "EXAMPLE_host_entries_to_pass_down": [
        [ "^^", "get", "exchange_collection" ],
        [ "^^", "dig", "execution_entry.model_entry" ]
    ],
    "host_entries_to_pass_down": [
        [ "^^", "get", "exchange_collection" ]
    ],
    "EXAMPLE_host_paths_to_pass_down": [
        "/etc/resolv.conf",
        "/data/models"
    ],
    "host_paths_to_pass_down": [],

    "host_entries_mapping": [ "^^", "host_entries_mapping" ],
    "container_entries_access": [ "^^", "container_entries_access" ],
    "host_kernel_path": [ "^", "kernel_path" ],
    "in_docker_kernel_path": "/mnt/axs",
    "container_id": [ "^^", "execute", [[
        [ "get", "docker_tool" ],
        [ "run", [], {
            "docker_image": [ "^^", "get", "docker_image" ],
            "docker_image_tag": [ "^^", "get", "docker_image_tag" ],
            "docker_run_extra_options": [ "^^", "get", "docker_run_extra_options" ],
            "cmd_key": "run",
            "capture_output": true,
            "docker_options": [ "^^", "substitute", "-it -d --rm --user #{user_in_docker}# #{host_entries_mapping}# #{docker_run_extra_options}#" ],
            "run_in_docker": [ "^^", "substitute", "sh -c 'sleep 3 && watch -g #{in_docker_kernel_path}#/axs byquery #{__modified_query}# --- 2>/dev/null'" ]
        } ]
    ]] ],
    "pipeline": [ "^^", "execute", [[
        [ "get", "docker_tool" ],
        [ "run", [], {
            "docker_container": [ "^^", "get", "container_id" ],
            "cmd_key": "exec",
            "docker_options": [ "^^", "substitute", "-it --user #{user_in_docker}#" ],
            "run_in_docker": [ "^^", "substitute", "#{container_entries_access}# , byquery #{__modified_query}#  --.#{execution_entry_name}#.#{execution_entry_product_collection_name}#=#{exchange_collection_name}#" ]
        } ],
        [ ],
        [ "get", "exchange_collection" ],
        [ "reload" ],
        [ "byquery", [[ "^^", "get", "__query" ]] ]
    ]] ]
}
