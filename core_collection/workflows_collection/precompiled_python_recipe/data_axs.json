{
    "_producer_rules": [
        [ [ "downloaded", "precompiled_python" ], [["get_kernel"],["byname","downloader"],["download"]], {

            "release_date": "20260114",
            "minor_version": 13,

            "minor_to_patch": {
                "10":   "19",
                "11":   "14",
                "12":   "12",
                "13":   "11",
                "14":   "2",
                "15":   "0a5"
            },
            "str_minor": [ "AS^IS", "^^", "execute", [[
                [ "get", "minor_version" ],
                0,
                [ "func", "str" ]
            ]] ],
            "patch_version": [ "AS^IS", "^^", "execute", [[
                [ "get", "minor_to_patch" ],
                [ "get", [ "^^", "get", "str_minor" ] ]
            ]] ],
            "full_version": [ "AS^IS", "^^", "substitute", "3.#{minor_version}#.#{patch_version}#" ],

            "url": [ "AS^IS", "^^", "case", [ [ "^", "func", "platform.system"] ,
                "Darwin",   [ "^^", "substitute", "https://github.com/astral-sh/python-build-standalone/releases/download/#{release_date}#/cpython-#{full_version}#+#{release_date}#-x86_64-apple-darwin-install_only.tar.gz" ],
                "Linux",    [ "^^", "substitute", "https://github.com/astral-sh/python-build-standalone/releases/download/#{release_date}#/cpython-#{full_version}#+#{release_date}#-x86_64-unknown-linux-gnu-install_only.tar.gz" ],
                "Windows",  [ "^^", "substitute", "https://github.com/astral-sh/python-build-standalone/releases/download/#{release_date}#/cpython-#{full_version}#+#{release_date}#-x86_64-pc-windows-msvc-install_only.tar.gz" ]
            ] ]
        } ],

        [ [ "extracted",  "precompiled_python" ], [["get_kernel"],["byname","extractor"],["extract"]], {
            "archive_path": [ "AS^IS", "^^", "execute", [[
                [ "get_kernel" ],
                [ "byquery", [[ "^^", "substitute", "downloaded,precompiled_python,minor_version=#{minor_version}#" ]] ],
                [ "get_path" ]
            ]] ],
            "newborn_parent_names": [ "shell" ],
            "rel_result_path": [  "AS^IS", "AS^IS", "AS^IS", "^^", "find_file", "^python3$", { "return_full": true } ],
            "exe_path": [ "AS^IS", "AS^IS", "AS^IS", "^^", "get_path" ]
        } ]
    ]
}
